# Line endings are pinned here so a fresh clone is byte-identical regardless of
# each machine's core.autocrlf setting.
* text=auto eol=lf

# The launcher requires CRLF as a hard project requirement: keep it CRLF on
# checkout everywhere.
scripts/ui_lancher11.py text eol=crlf

# Never normalise binary assets.
*.png binary
*.pdf binary
*.pptx binary
*.gif binary
